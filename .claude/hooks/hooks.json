{
  "description": "vibe flow hooks — inject (UserPromptSubmit), guard (PreToolUse), gate (Stop). Thin shells over .agents/skills/vibe/scripts/; the allow/warn/block policy lives once in detect-context.sh. Earned warn-first; exit 0 on any missing keystone (graceful degrade).",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/user-prompt-submit-inject.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/pre-tool-use-guard.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/.claude/hooks/stop-gate.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
