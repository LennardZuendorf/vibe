{
  "name": "agentkit-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "app:build": "turbo build --filter=agentkit-app",
    "app:deploy": "turbo build --filter=agentkit-app && vercel --prod",
    "app:dev": "turbo dev --filter=agentkit-app",
    "build": "turbo build",
    "clean": "turbo clean",
    "cli:build": "turbo build --filter=@agentkit/cli",
    "cli:dev": "turbo dev --filter=@agentkit/cli",
    "cli:publish": "turbo build --filter=@agentkit/cli && cd packages/cli && npm publish",
    "cli:test": "turbo test --filter=@agentkit/cli",
    "dev": "turbo dev",
    "format": "turbo format",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test"
  },
  "dependencies": {
    "@edge-runtime/vm": "latest",
    "@hookform/resolvers": "^3.9.1",
    "@radix-ui/react-accordion": "latest",
