{
  "name": "agentkit",
  "version": "1.0.0",
  "description": "A CLI tool to install AgentKit configurations into repositories.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "agentkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "kits"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "postbuild": "echo '#!/usr/bin/env node' | cat - dist/index.js > temp && mv temp dist/index.js && chmod +x dist/index.js"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "framework",
    "agentkit"
  ],
  "author": "AgentKit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ignitr/agent-kit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://agentkit.dev",
  "dependencies": {
    "commander": "^12.0.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "typescript": "^5.8.3",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
} 